# ─── Environment ─────────────────────────────────────────────────────────────
# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/whatsapp-clone

# JWT secret — use a long, random string in production
JWT_SECRET=replace_with_a_long_random_secret

# Server port
PORT=5005

# Redis (optional — falls back to localhost:6379)
REDIS_URL=redis://localhost:6379

# Firebase Admin SDK (base64-encoded service account JSON)
# Only needed if you use Firebase Storage for image uploads.
# FIREBASE_SERVICE_ACCOUNT=<base64-encoded-json>
